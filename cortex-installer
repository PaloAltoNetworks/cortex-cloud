# ═════════════════════════════════════════════════════════════════════════════
# Prerequisite checks
# ═════════════════════════════════════════════════════════════════════════════
check_prerequisites() {
  local required_cmds=("$@")
  local cmd
  for cmd in "${required_cmds[@]}"; do
    if ! command -v "$cmd" &>/dev/null; then
      error "Required command '$cmd' is not installed. Please install it and retry."
      exit 1
    fi
  done
}

# ═════════════════════════════════════════════════════════════════════════════
# Helm version check (require v3.8+ for OCI support)
# ═════════════════════════════════════════════════════════════════════════════
check_helm_version() {
  local helm_version_str
  helm_version_str=$(helm version --short 2>/dev/null | sed 's/^v//' | cut -d'+' -f1)

  if [[ -z "$helm_version_str" ]]; then
    warn "Could not determine Helm version. Proceeding, but OCI support requires v${MIN_HELM_MAJOR}.${MIN_HELM_MINOR}+."
    log "WARN: Could not determine Helm version"
    return
  fi

  local major minor
  major=$(echo "$helm_version_str" | cut -d'.' -f1)
  minor=$(echo "$helm_version_str" | cut -d'.' -f2)

  if [[ "$major" -lt "$MIN_HELM_MAJOR" ]] || { [[ "$major" -eq "$MIN_HELM_MAJOR" ]] && [[ "$minor" -lt "$MIN_HELM_MINOR" ]]; }; then
    error "Helm v${MIN_HELM_MAJOR}.${MIN_HELM_MINOR}+ is required for OCI support (found v${helm_version_str})."
    error "Please upgrade Helm: https://helm.sh/docs/intro/install/"
    exit 1
  fi

  ok "Helm version: v${helm_version_str} (meets v${MIN_HELM_MAJOR}.${MIN_HELM_MINOR}+ requirement)"
  log "Helm version: v${helm_version_str}"
}

# ═════════════════════════════════════════════════════════════════════════════
# Input validation
# ═════════════════════════════════════════════════════════════════════════════
validate_registry() {
  local registry="$1"

  # Reject empty
  if [[ -z "$registry" ]]; then
    error "Registry value cannot be empty."
    exit 1
  fi

  # Allow only safe characters: alphanumeric, dots, dashes, underscores, slashes, colons
  if [[ ! "$registry" =~ ^[a-zA-Z0-9._/:@-]+$ ]]; then
    error "Invalid registry value: '$registry'"
    error "Registry must contain only alphanumeric characters, dots, dashes, underscores, slashes, and colons."
    exit 1
  fi

  # Reject values that look like shell injection attempts
  if [[ "$registry" == *".."* ]] || [[ "$registry" == *";"* ]] || [[ "$registry" == *"|"* ]] || [[ "$registry" == *"&"* ]]; then
    error "Invalid registry value: '$registry' — contains suspicious characters."
    exit 1
  fi

  log "Registry validated: $registry"
}

# ═════════════════════════════════════════════════════════════════════════════
# Print summary table (DRY — used by both pull and push summaries)
# ═════════════════════════════════════════════════════════════════════════════
# Arguments:
#   $1 - title (e.g. "PULL SUMMARY" or "PUSH SUMMARY")
#   $2 - summary file path
#   $3 - label for OK count (e.g. "Pulled" or "Pushed")
# Outputs:
#   total_ok, total_fail, total_skip as global variables
print_summary_table() {
  local title="$1"
  local summary_file="$2"
  local ok_label="$3"

  echo ""
  echo "╔══════════════════════════════════════════════════════════════════════════════════╗"
  echo "║                           ${title}                                         ║"
  echo "╠══════════════════════════════════════════════════════════════════════════════════╣"
  echo ""

  printf "  ${CYAN}%-20s %-35s %-12s %-6s %-20s${NC}\n" "COMPONENT" "IMAGE" "TAG" "STATUS" "ARCHITECTURES"
  printf "  %-20s %-35s %-12s %-6s %-20s\n" "────────────────────" "───────────────────────────────────" "────────────" "──────" "────────────────────"

  total_ok=0
  total_fail=0
  total_skip=0

  if [[ -f "$summary_file" ]]; then
    local status component img_name img_tag archs _note status_icon
    while IFS='|' read -r status component img_name img_tag archs _note; do
      case "$status" in
        OK)
          status_icon="${GREEN}✓${NC}"
          total_ok=$((total_ok + 1))
          ;;
        FAILED)
          status_icon="${RED}✗${NC}"
          total_fail=$((total_fail + 1))
          ;;
        SKIPPED)
          status_icon="${YELLOW}⊘${NC}"
          total_skip=$((total_skip + 1))
          ;;
        *)
          status_icon="?"
          ;;
      esac
      printf "  %-20s %-35s %-12s " "$component" "$img_name" "$img_tag"
      echo -e "${status_icon}      ${archs}"
    done < "$summary_file"
  fi

  echo ""
  printf "  %-20s\n" "────────────────────────────────────────"
  echo -e "  ${GREEN}${ok_label}:${NC}  $total_ok    ${RED}Failed:${NC}  $total_fail    ${YELLOW}Skipped:${NC}  $total_skip"
  echo ""

  log "${title}: ${ok_label}=$total_ok Failed=$total_fail Skipped=$total_skip"
}

# ═════════════════════════════════════════════════════════════════════════════
# Backend API caller (adapted from reference script)
# ═════════════════════════════════════════════════════════════════════════════
# Globals set by ensure_backend_auth: TOKEN, CH_API
TOKEN=""

backend_api() {
  local method="$1" path="$2" data="${3:-}"
  local resp code body

  local -a headers=("-H" "Accept: application/json")
  [[ -n "${TOKEN:-}" ]] && headers+=("-H" "X-Auth: $TOKEN")
  [[ -n "$data" ]] && headers+=("-H" "Content-Type: application/json" -d "$data")

  resp=$(curl -sS "${headers[@]}" -w "\n%{http_code}" --max-time 30 -X "$method" "$path") || {
    error "Network error calling $method $path"
    return 1
  }

  code=$(tail -n1 <<<"$resp")
  body=$(sed '$d' <<<"$resp")

  if ! echo "$body" | jq . >/dev/null 2>&1; then
    error "API $method $path returned invalid JSON (HTTP $code)"
    return 1
  fi

  if [[ "$code" -ge 300 ]]; then
    local err_msg
    err_msg=$(echo "$body" | jq -r '.message // .detail // empty')
    error "API $method $path failed: HTTP $code — $err_msg"
    return 1
  fi

  log "API $method $path → HTTP $code"
  echo "$body"
}

# ═════════════════════════════════════════════════════════════════════════════
# Extract distribution.id and distribution.url from values file
# ═════════════════════════════════════════════════════════════════════════════
# Reads distribution.id and distribution.url from the provided values YAML file.
# Sets globals: DIST_ID, DIST_URL (if distribution.url is present)
extract_distribution_id() {
  local values_file="$1"

  info "Extracting distribution.id from values file..."

  DIST_ID=$(yq '.distribution.id' "$values_file" 2>/dev/null || true)
  # yq returns "null" for missing keys
  [[ "$DIST_ID" == "null" ]] && DIST_ID=""

  if [[ -z "$DIST_ID" ]]; then
    error "Could not extract 'distribution.id' from $values_file"
    error "The values file must contain a 'distribution.id' field for backend authentication."
    exit 1
  fi

  ok "distribution.id extracted."
  log "distribution.id = $DIST_ID"

  # Also extract distribution.url if present, to override the default DIST_URL
  local dist_url_from_values
  dist_url_from_values=$(yq '.distribution.url' "$values_file" 2>/dev/null || true)
  [[ "$dist_url_from_values" == "null" ]] && dist_url_from_values=""

  if [[ -n "$dist_url_from_values" ]]; then
    DIST_URL="$dist_url_from_values"
    ok "distribution.url extracted: $DIST_URL"
    log "distribution.url = $DIST_URL (from values file)"
  fi
}

# ═════════════════════════════════════════════════════════════════════════════
# Backend authentication
# ═════════════════════════════════════════════════════════════════════════════
# Resolves CH_API (if needed) and registers via distribution.id to get a token.
# This is a one-shot auth — no secrets are read or saved.
# Requires: DIST_ID to be set (call extract_distribution_id first)
# Sets globals: TOKEN, CH_API
ensure_backend_auth() {
  info "Authenticating to backend API..."

  if [[ -z "$DIST_ID" ]]; then
    error "distribution.id is required — extract it from the values file first."
    exit 1
  fi

  # Resolve CH_API from distribution service if not provided
  if [[ -z "$CH_API" ]]; then
    info "Resolving CH_API from Distribution Service..."
    CH_API=$(curl -sf "${DIST_URL}/operations/provision/register-url/${DIST_ID}" | jq -r '.chUrl') || {
      error "Failed to resolve CH_API from distribution service."
      exit 1
    }
    ok "Resolved CH_API."
    log "Resolved CH_API from distribution service"
  fi

  # Register to get a token
  info "Registering with backend..."
  local resp
  resp=$(backend_api POST "$CH_API/k8s/api/v2/auth" "$(jq -n --arg d "$DIST_ID" '{distributionID:$d}')") || {
    error "Registration failed."
    exit 1
  }

  TOKEN=$(echo "$resp" | jq -r '.tokens.token // empty')

  if [[ -z "$TOKEN" ]]; then
    error "Registration incomplete — no token in response."
    exit 1
  fi

  ok "Authenticated successfully."
  log "Auth: registered and obtained token"
}

# ═════════════════════════════════════════════════════════════════════════════
# Pull chart and values from the backend API
# ═════════════════════════════════════════════════════════════════════════════
# Sets: chart_tgz, chart_values, work_dir
pull_chart_from_backend() {
  info "Fetching chart '$CHART' from backend API..."
  log "Fetching chart from backend: $CH_API/k8s/v1/charts/$CHART"

  local resp
  resp=$(backend_api GET "$CH_API/k8s/v1/charts/$CHART") || {
    error "Failed to fetch chart from backend API."
    exit 1
  }

  work_dir=$(mktemp -d /tmp/cortex-backend-chart-XXXXXX)
  register_temp_dir "$work_dir"

  # Decode chart .tgz from base64 response
  echo "$resp" | jq -r '.chart' | base64_decode > "$work_dir/chart.tgz"
  chart_tgz="$work_dir/chart.tgz"

  if [[ ! -s "$chart_tgz" ]]; then
    error "Backend returned an empty chart payload."
    exit 1
  fi

  ok "Chart archive downloaded from backend."
  log "Chart archive saved to $chart_tgz"

  # Decode values from base64 response (backend returns JSON)
  echo "$resp" | jq -r '.values // "{}"' | base64_decode > "$work_dir/values.json"
  chart_values="$work_dir/values.json"

  if [[ ! -s "$chart_values" ]]; then
    warn "Backend returned empty values — using defaults from chart."
    # Extract values.yaml from the chart archive as fallback
    local extract_dir="$work_dir/extracted"
    mkdir -p "$extract_dir"
    tar -xzf "$chart_tgz" -C "$extract_dir"
    local found_values
    found_values=$(find "$extract_dir" -name 'values.yaml' -print 2>/dev/null | head -1)
    if [[ -n "$found_values" ]]; then
      cp "$found_values" "$chart_values"
      ok "Extracted values.yaml from chart archive."
    else
      warn "No values.yaml found in chart archive either."
    fi
  else
    ok "Values file downloaded from backend."
  fi

  log "Chart and values fetched from backend"
}

# ═════════════════════════════════════════════════════════════════════════════
# Extract image.repository and credentials from backend-provided values
# ═════════════════════════════════════════════════════════════════════════════
# If a --values file is provided, use it. Otherwise, extract from the
# backend-provided values.yaml.
# Sets: image_repository, registry_host, project_path, sa_json_key
extract_credentials_from_values() {
  local values_source="$1"

  info "Extracting image.repository from values..."

  image_repository=$(yq '.image.repository' "$values_source" 2>/dev/null || true)
  # yq returns "null" for missing keys
  [[ "$image_repository" == "null" ]] && image_repository=""

  if [[ -z "$image_repository" ]]; then
    error "Could not extract 'image.repository' from values."
    exit 1
  fi

  ok "image.repository = $image_repository"
  log "image.repository = $image_repository"

  registry_host=$(echo "$image_repository" | cut -d'/' -f1)
  project_path=$(echo "$image_repository" | cut -d'/' -f2-)

  info "Registry host: $registry_host"
  info "Project path:  $project_path"
  log "Registry host: $registry_host, Project path: $project_path"

  # Extract and decode dockerPullSecret for Docker login
  info "Extracting dockerPullSecret from values..."

  local docker_pull_secret
  docker_pull_secret=$(yq '.dockerPullSecret' "$values_source" 2>/dev/null || true)
  # yq returns "null" for missing keys
  [[ "$docker_pull_secret" == "null" ]] && docker_pull_secret=""

  if [[ -z "$docker_pull_secret" ]]; then
    docker_pull_secret=$(grep -E '^\s*dockerPullSecret:\s*' "$values_source" 2>/dev/null | sed 's/^[[:space:]]*dockerPullSecret:[[:space:]]*//' || true)
  fi

  if [[ -z "$docker_pull_secret" ]]; then
    warn "Could not extract 'dockerPullSecret' from values. Docker login to source registry may fail."
    sa_json_key=""
    return
  fi

  ok "dockerPullSecret extracted."
  log "dockerPullSecret extracted"

  sa_json_key=$(echo "$docker_pull_secret" | base64_decode 2>/dev/null | \
    jq -r '.auths | to_entries[0].value.password' 2>/dev/null || echo "")

  if [[ -z "$sa_json_key" || "$sa_json_key" == "null" ]]; then
    warn "Failed to decode service account JSON key from dockerPullSecret."
    sa_json_key=""
    return
  fi

  ok "Service account JSON key decoded."
  log "Service account JSON key decoded"
}

# ═════════════════════════════════════════════════════════════════════════════
# Login to source registry using extracted credentials
# ═════════════════════════════════════════════════════════════════════════════
login_to_source_registry() {
  if [[ -z "${sa_json_key:-}" ]]; then
    warn "No service account key available — skipping source registry login."
    return
  fi

  info "Logging in to source registry: $registry_host ..."

  echo "$sa_json_key" | docker login "$registry_host" \
    --username _json_key \
    --password-stdin 2>/dev/null && {
    ok "Docker registry login successful."
    log "Docker registry login to $registry_host successful"
  } || {
    warn "Docker login to $registry_host failed. Image pulls may fail."
    log "Docker login to $registry_host failed"
  }
}

# ═════════════════════════════════════════════════════════════════════════════
# Mirror command implementation
# ═════════════════════════════════════════════════════════════════════════════
cmd_mirror() {
  local chart_dir=""
  local values_file=""
  local push_target=""
  local docker_pull_secret_override=""
  local no_pull_secret=false
  local dry_run=false

  # ─── Parse arguments ─────────────────────────────────────────────────────
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --chart-dir)
        if [[ -z "${2:-}" ]]; then
          error "--chart-dir requires a directory path argument."
          exit 1
        fi
        chart_dir="$2"
        shift 2
        ;;
      --values)
        if [[ -z "${2:-}" ]]; then
          error "--values requires a file path argument."
          exit 1
        fi
        values_file="$2"
        shift 2
        ;;
      --private-registry)
        if [[ -z "${2:-}" ]]; then
          error "--private-registry requires a registry argument."
          exit 1
        fi
        push_target="$2"
        shift 2
        ;;
      --docker-pull-secret)
        if [[ -z "${2:-}" ]]; then
          error "--docker-pull-secret requires a base64-encoded secret argument."
          exit 1
        fi
        docker_pull_secret_override="$2"
        shift 2
        ;;
      --docker-pull-secret-file)
        if [[ -z "${2:-}" ]]; then
          error "--docker-pull-secret-file requires a file path argument."
          exit 1
        fi
        if [[ ! -f "$2" ]]; then
          error "Docker pull secret file not found: $2"
          exit 1
        fi
        # Read the file and base64-encode it to produce the dockerPullSecret value
        docker_pull_secret_override=$(cat "$2" | base64 2>/dev/null | tr -d '\n')
        if [[ -z "$docker_pull_secret_override" ]]; then
          error "Failed to base64-encode the docker pull secret file: $2"
          exit 1
        fi
        info "Docker pull secret loaded from file: $2"
        shift 2
        ;;
      --no-pull-secret)
        no_pull_secret=true
        shift
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      -h|--help)
        mirror_usage
        ;;
      *)
        error "Unknown argument for 'mirror': $1"
        echo ""
        mirror_usage
        ;;
    esac
  done

  # ─── Validate required arguments ─────────────────────────────────────────
  if [[ -z "$chart_dir" ]]; then
    error "Missing required flag: --chart-dir <dir>"
    error "Run '${PROGRAM_NAME} get-chart' first to download the chart, then pass the output directory here."
    echo ""
    mirror_usage
  fi

  if [[ -z "$values_file" ]]; then
    error "Missing required flag: --values <values-file>"
    echo ""
    mirror_usage
  fi

  if [[ -z "$push_target" ]]; then
    error "Missing required flag: --private-registry <registry>"
    echo ""
    mirror_usage
  fi

  if [[ ! -d "$chart_dir" ]]; then
    error "Chart directory not found: $chart_dir"
    error "Run '${PROGRAM_NAME} get-chart' first to download the chart."
    exit 1
  fi

  # Locate backend-values.yaml in the chart directory
  local backend_values_file="$chart_dir/backend-values.yaml"
  # Fallback to .json for backward compatibility
  if [[ ! -f "$backend_values_file" && -f "$chart_dir/backend-values.yaml" ]]; then
    backend_values_file="$chart_dir/backend-values.yaml"
  fi
  if [[ ! -f "$backend_values_file" ]]; then
    error "backend-values.yaml not found in $chart_dir"
    error "Run '${PROGRAM_NAME} get-chart --values <values-file>' first."
    exit 1
  fi

  # Locate the chart .tgz in the chart directory
  local chart_tgz_file
  chart_tgz_file=$(find "$chart_dir" -maxdepth 1 -name '*.tgz' -print 2>/dev/null | head -1)
  if [[ -z "$chart_tgz_file" ]]; then
    error "No chart .tgz found in $chart_dir"
    error "Run '${PROGRAM_NAME} get-chart --values <values-file>' first."
    exit 1
  fi

  if [[ ! -f "$values_file" ]]; then
    error "Values file not found: $values_file"
    exit 1
  fi

  validate_registry "$push_target"

  # ─── Enforce dockerPullSecret for private registry ──────────────────────
  if [[ -z "$docker_pull_secret_override" && "$no_pull_secret" != "true" ]]; then
    error "A dockerPullSecret is required when mirroring to a private registry."
    error "The Kubernetes cluster needs this secret to pull images from your private registry."
    echo ""
    error "Provide one of:"
    error "  --docker-pull-secret <base64-encoded-secret>"
    error "  --docker-pull-secret-file <path-to-docker-config.json>"
    echo ""
    error "If your cluster already has pre-configured access to the registry, use:"
    error "  --no-pull-secret"
    exit 1
  fi

  # ─── Check prerequisites ────────────────────────────────────────────────
  check_prerequisites docker base64 yq jq curl

  if ! docker buildx version &>/dev/null; then
    error "'docker buildx' is required for pushing multi-arch manifests."
    error "Install it: https://docs.docker.com/buildx/install/"
    exit 1
  fi

  # ─── Init logging ───────────────────────────────────────────────────────
  init_log_file
  log "Command: mirror"
  log "Chart dir: $chart_dir"
  log "Values file: $values_file"
  log "Push target: $push_target"
  log "Dry run: $dry_run"
  log "Docker pull secret override: ${docker_pull_secret_override:+provided}"

  # ─── Banner ──────────────────────────────────────────────────────────────
  echo ""
  echo -e "${BOLD}╔══════════════════════════════════════════════════════════════════════════════════╗${NC}"
  echo -e "${BOLD}║                     ${PROGRAM_NAME} mirror                               ║${NC}"
  echo -e "${BOLD}╠══════════════════════════════════════════════════════════════════════════════════╣${NC}"
  echo ""
  info "Chart dir:     $chart_dir"
  info "Chart:         $chart_tgz_file"
  info "Push target:   $push_target"
  info "Values file:   $values_file"
  if [[ "$dry_run" == "true" ]]; then
    info "Mode:          DRY RUN (no images will be pulled or pushed)"
  fi
  echo ""

  # ─── Step 1: Extract credentials and login to source registry ────────────
  # Convert backend values to JSON for internal processing (handles both YAML and JSON input)
  local backend_values_json_tmp
  backend_values_json_tmp=$(mktemp /tmp/cortex-backend-values-XXXXXX.json)
  register_temp_file "$backend_values_json_tmp"
  if [[ "$backend_values_file" == *.yaml || "$backend_values_file" == *.yml ]]; then
    yq -o=json '.' "$backend_values_file" > "$backend_values_json_tmp"
  else
    cp "$backend_values_file" "$backend_values_json_tmp"
  fi

  info "Step 1/3: Extracting credentials and logging in to source registry..."

  # Extract credentials from user-provided values file (dockerPullSecret, image.repository)
  image_repository=""
  registry_host=""
  project_path=""
  sa_json_key=""
  extract_credentials_from_values "$values_file"
  login_to_source_registry

  # ─── Step 2: Pull bundle images ──────────────────────────────────────────
  info "Step 2/3: Pulling bundle images..."

  # Extract chart's values.yaml from the .tgz to get image name and tag
  local chart_extract_dir
  chart_extract_dir=$(mktemp -d /tmp/cortex-chart-values-XXXXXX)
  register_temp_dir "$chart_extract_dir"
  tar -xzf "$chart_tgz_file" -C "$chart_extract_dir" 2>/dev/null || true
  local chart_values_yaml
  chart_values_yaml=$(find "$chart_extract_dir" -name 'values.yaml' -print 2>/dev/null | head -1)

  if [[ -z "$chart_values_yaml" || ! -f "$chart_values_yaml" ]]; then
    error "Could not extract values.yaml from chart archive."
    exit 1
  fi

  # Build image list from backend values only (only mirror images the backend provides)
  # Backend values has: bundle.<component>.image.{repository} (which components are enabled)
  # Chart values has: bundle.<component>.image.{name, tag} (image details)
  # We iterate over backend bundle keys and look up name/tag from chart values
  local chart_values_json
  chart_values_json=$(yq -o=json '.' "$chart_values_yaml")

  local images_json
  images_json=$(jq -n \
    --argjson chart "$chart_values_json" \
    --slurpfile backend "$backend_values_json_tmp" \
    '[
      $backend[0].bundle | to_entries[] |
      select(.value.image != null) |
      .key as $comp |
      ($chart.bundle[$comp].image // {}) as $chart_img |
      select($chart_img.name != null and $chart_img.name != "") |
      {
        component: $comp,
        name: $chart_img.name,
        tag: (.value.image.tag // ($chart_img.tag // "")),
        repository: (.value.image.repository // ($chart_img.repository // ""))
      }
    ]')

  if [[ -z "$images_json" || "$images_json" == "[]" ]]; then
    warn "No bundle images found in chart values."
    exit 0
  fi

  local image_count
  image_count=$(echo "$images_json" | jq length)
  info "Found $image_count bundle images to pull."
  log "Found $image_count bundle images"
  echo ""

  # Tracking for the summary
  local summary_file
  summary_file=$(mktemp /tmp/cortex-pull-summary-XXXXXX.txt)
  register_temp_file "$summary_file"

  # ── Process images ───────────────────────────────────────────────────────
  local component img_name img_tag img_repo full_image
  while read -r img_entry; do
    component=$(echo "$img_entry" | jq -r '.component')
    img_name=$(echo "$img_entry" | jq -r '.name')
    img_tag=$(echo "$img_entry" | jq -r '.tag')
    img_repo=$(echo "$img_entry" | jq -r '.repository')

    # Skip images with empty tag
    if [[ -z "$img_tag" ]]; then
      warn "[$component] Skipping '$img_name' — no tag specified in chart values."
      echo "SKIPPED|${component}|${img_name}|${img_tag}|N/A|no tag specified" >> "$summary_file"
      log "SKIPPED $component/$img_name — no tag"
      continue
    fi

    # Use per-component repository from backend values, fall back to global image_repository
    local effective_repo="${img_repo:-$image_repository}"
    full_image="${effective_repo}/${img_name}:${img_tag}"

    # ── Dry-run mode: just report what would happen ──────────────────────
    if [[ "$dry_run" == "true" ]]; then
      info "[$component] [DRY RUN] Would pull: $full_image"
      echo "OK|${component}|${img_name}|${img_tag}|dry-run|" >> "$summary_file"
      log "DRY RUN: would pull $full_image"
      echo ""
      continue
    fi

    info "[$component] Pulling (multi-arch): $full_image"
    log "Pulling: $full_image"

    # Inspect the manifest to discover available architectures
    local archs="" manifest_json=""
    manifest_json=$(docker manifest inspect "$full_image" 2>/dev/null || true)

    # If the image doesn't exist in the registry, skip it gracefully
    if [[ -z "$manifest_json" ]]; then
      if docker pull "$full_image" 2>/dev/null; then
        archs=$(docker inspect "$full_image" 2>/dev/null | jq -r '.[0].Architecture // "platform info unavailable"' 2>/dev/null || echo "platform info unavailable")
        ok "[$component] Successfully pulled: $full_image"
        echo "OK|${component}|${img_name}|${img_tag}|${archs}|" >> "$summary_file"
        log "OK $component $full_image ($archs)"
        echo ""
        continue
      fi
      warn "[$component] Image not found in registry — skipping: $full_image"
      echo "SKIPPED|${component}|${img_name}|${img_tag}|N/A|image not found in registry" >> "$summary_file"
      log "SKIPPED $component $full_image — not found"
      echo ""
      continue
    fi

    archs=$(echo "$manifest_json" | jq -r '
      if .manifests then
        [.manifests[] | select(.platform.os == "linux") | .platform.architecture] | unique | join(", ")
      else
        "single-arch"
      end
    ' 2>/dev/null || echo "platform info unavailable")

    # Pull each available platform explicitly to preserve multi-arch
    local pull_ok=false
    local platforms
    platforms=$(echo "$manifest_json" | jq -r '
      if .manifests then
        [.manifests[] | select(.platform.os == "linux") | "\(.platform.os)/\(.platform.architecture)"] | unique | .[]
      else
        empty
      end
    ' 2>/dev/null || true)

    if [[ -n "$platforms" ]]; then
      local platform
      for platform in $platforms; do
        info "[$component]   Pulling platform: $platform"
        if docker pull --platform "$platform" "$full_image" 2>/dev/null; then
          ok "[$component]   ✓ $platform"
        else
          warn "[$component]   ✗ $platform (pull failed, skipping this platform)"
        fi
      done
      if docker manifest inspect "$full_image" &>/dev/null || docker inspect "$full_image" &>/dev/null; then
        pull_ok=true
      fi
    else
      if docker pull "$full_image" 2>/dev/null; then
        pull_ok=true
      fi
    fi

    if [[ "$pull_ok" == "true" ]]; then
      ok "[$component] Successfully pulled: $full_image"
      echo "OK|${component}|${img_name}|${img_tag}|${archs}|" >> "$summary_file"
      log "OK $component $full_image ($archs)"
    else
      warn "[$component] Could not pull image — skipping: $full_image"
      echo "SKIPPED|${component}|${img_name}|${img_tag}|${archs:-N/A}|pull failed" >> "$summary_file"
      log "SKIPPED $component $full_image — pull failed"
    fi
    echo ""
  done < <(echo "$images_json" | jq -c '.[]')

  # ─── Print pull summary ─────────────────────────────────────────────────
  info "Chart dir:   $chart_dir"
  info "Registry:    ${registry_host:-N/A}"
  info "Repository:  ${image_repository:-N/A}"
  echo ""

  # total_ok, total_fail, total_skip are set by print_summary_table
  local total_ok total_fail total_skip
  print_summary_table "PULL SUMMARY" "$summary_file" "Pulled"

  # ─── Step 3: Push to target registry ─────────────────────────────────────
  echo ""
  echo "╔══════════════════════════════════════════════════════════════════════════════════╗"
  echo "║                     PUSHING TO TARGET REGISTRY                                  ║"
  echo "╠══════════════════════════════════════════════════════════════════════════════════╣"
  echo ""

  info "Step 3/3: Pushing images to target registry..."
  log "Step 3/3: Pushing to $push_target"

  local target_host
  target_host=$(echo "$push_target" | cut -d'/' -f1)

  if [[ "$dry_run" != "true" ]]; then
    # ─── Verify and perform target registry login ────────────────────────────
    info "Checking Docker login to target registry: $target_host ..."

    local docker_config="${DOCKER_CONFIG:-$HOME/.docker}"
    local logged_in=false
    if [[ -f "$docker_config/config.json" ]]; then
      if jq -e --arg host "$target_host" '.auths[$host] // .auths["https://\($host)"] // empty' "$docker_config/config.json" &>/dev/null; then
        logged_in=true
      fi
    fi

    if [[ "$logged_in" == "true" ]]; then
      ok "Already logged in to $target_host (credentials found in Docker config)."
    else
      warn "No existing credentials found for $target_host."
      info "Attempting interactive Docker login to $target_host ..."
      echo ""
      if docker login "$target_host"; then
        ok "Successfully logged in to $target_host."
        log "Docker login to $target_host successful"
      else
        error "Docker login to $target_host failed."
        error "Please run 'docker login $target_host' manually and retry."
        exit 1
      fi
    fi
  fi

  local push_summary_file
  push_summary_file=$(mktemp /tmp/cortex-push-summary-XXXXXX.txt)
  register_temp_file "$push_summary_file"

  info "Pushing images to $push_target ..."
  info "Using 'docker buildx imagetools create' to preserve multi-arch manifests."
  echo ""

  if [[ -f "$summary_file" ]]; then
    local status component img_name img_tag archs _note
    while IFS='|' read -r status component img_name img_tag archs _note; do
      if [[ "$status" != "OK" ]]; then
        echo "SKIPPED|${component}|${img_name}|${img_tag}|${archs}|not pulled" >> "$push_summary_file"
        continue
      fi

      local src_image="${image_repository}/${img_name}:${img_tag}"
      local dst_image="${push_target}/${img_name}:${img_tag}"

      # ── Dry-run mode ─────────────────────────────────────────────────────
      if [[ "$dry_run" == "true" ]]; then
        info "[$component] [DRY RUN] Would push: $src_image → $dst_image"
        echo "OK|${component}|${img_name}|${img_tag}|${archs}|dry-run" >> "$push_summary_file"
        log "DRY RUN: would push $src_image → $dst_image"
        echo ""
        continue
      fi

      info "[$component] Copying: $src_image → $dst_image"
      log "Pushing: $src_image → $dst_image"

      if docker buildx imagetools create --tag "$dst_image" "$src_image" 2>/dev/null; then
        ok "[$component] Successfully pushed (multi-arch): $dst_image"
        echo "OK|${component}|${img_name}|${img_tag}|${archs}|" >> "$push_summary_file"
        log "OK push $component $dst_image"
      else
        warn "[$component] buildx imagetools failed, attempting docker tag+push fallback..."
        if docker tag "$src_image" "$dst_image" 2>/dev/null && docker push "$dst_image" 2>/dev/null; then
          ok "[$component] Pushed (single-arch fallback): $dst_image"
          echo "OK|${component}|${img_name}|${img_tag}|${archs}|single-arch fallback" >> "$push_summary_file"
          log "OK push (fallback) $component $dst_image"
        else
          error "[$component] Failed to push: $dst_image"
          echo "FAILED|${component}|${img_name}|${img_tag}|${archs}|push failed" >> "$push_summary_file"
          log "FAILED push $component $dst_image"
        fi
      fi
      echo ""
    done < "$summary_file"
  fi

  # ─── Print push summary ─────────────────────────────────────────────────
  info "Source:  ${image_repository:-N/A}"
  info "Target:  $push_target"
  echo ""

  local push_ok push_fail push_skip
  print_summary_table "PUSH SUMMARY" "$push_summary_file" "Pushed"
  push_ok=$total_ok
  push_fail=$total_fail
  push_skip=$total_skip

  echo "╚══════════════════════════════════════════════════════════════════════════════════╝"

  # ─── Generate cortex-override-values.yaml ────────────────────────────────
  info "Generating cortex-override-values.yaml..."

  local namespace
  namespace=$(jq -r '.namespace.name // "panw"' "$backend_values_json_tmp" 2>/dev/null || echo "pan")

  local original_image_repo
  original_image_repo=$(jq -r '.image.repository // "N/A"' "$backend_values_json_tmp" 2>/dev/null || echo "N/A")

  local chart_tgz_basename
  chart_tgz_basename=$(basename "$chart_tgz_file")

  # Extract chart version from Chart.yaml inside the archive
  local chart_version_label="unknown"
  local extract_dir
  extract_dir=$(mktemp -d /tmp/cortex-chart-extract-XXXXXX)
  register_temp_dir "$extract_dir"
  tar -xzf "$chart_tgz_file" -C "$extract_dir" 2>/dev/null || true
  local chart_yaml
  chart_yaml=$(find "$extract_dir" -name 'Chart.yaml' -print 2>/dev/null | head -1)
  if [[ -n "$chart_yaml" ]]; then
    chart_version_label=$(yq '.version' "$chart_yaml" 2>/dev/null || echo "unknown")
    [[ "$chart_version_label" == "null" ]] && chart_version_label="unknown"
  fi

  local cortex_override_values_file="$chart_dir/cortex-override-values.yaml"

  # Generate the YAML body by modifying all image.repository references to point to the target registry
  # This updates: .image.repository (top-level) and .bundle.<component>.image.repository (per-component)
  # Build the jq filter — optionally inject dockerPullSecret for private registry access
  local jq_filter='(.image.repository = $target) | (.bundle |= (if . then with_entries(.value.image.repository = $target) else . end))'
  local -a jq_args=(--arg target "$push_target")

  if [[ -n "$docker_pull_secret_override" ]]; then
    jq_filter="${jq_filter} | (.dockerPullSecret = \$secret)"
    jq_args+=(--arg secret "$docker_pull_secret_override")
    info "dockerPullSecret will be injected into cortex-override-values.yaml"
    log "dockerPullSecret override provided — will be injected into override values"
  elif [[ "$no_pull_secret" == "true" ]]; then
    jq_filter="${jq_filter} | del(.dockerPullSecret)"
    info "dockerPullSecret will be excluded from cortex-override-values.yaml (--no-pull-secret)"
    log "dockerPullSecret excluded from override values (--no-pull-secret)"
  fi

  jq "${jq_args[@]}" "$jq_filter" "$backend_values_json_tmp" | yq -P > "$cortex_override_values_file.tmp"

  # Prepend the header comment
  cat > "$cortex_override_values_file" <<EOF
# ============================================================================
# cortex-override-values.yaml
# Generated by: ${PROGRAM_NAME} mirror
# Source: Backend API
# Original registry:  ${original_image_repo}
# Target registry:    ${push_target}
# Chart version:      ${chart_version_label}
#
# This file is a copy of the backend-provided values with image.repository
# updated to point to the mirrored target registry.
#
# Usage (install from local chart):
#   helm upgrade --install konnector ./${chart_tgz_basename} \\
#     --wait-for-jobs \\
#     --create-namespace \\
#     --namespace ${namespace} \\
#     --set deployedByLauncher=false \\
#     --values cortex-override-values.yaml
# ============================================================================

EOF
  cat "$cortex_override_values_file.tmp" >> "$cortex_override_values_file"
  rm -f "$cortex_override_values_file.tmp"

  ok "Override values generated: $cortex_override_values_file"
  log "Override values generated: $cortex_override_values_file"

  # ─── Final summary ──────────────────────────────────────────────────────
  echo ""
  echo -e "${BOLD}╔══════════════════════════════════════════════════════════════════════════════════╗${NC}"
  echo -e "${BOLD}║                        MIRROR COMPLETE                                         ║${NC}"
  echo -e "${BOLD}╠══════════════════════════════════════════════════════════════════════════════════╣${NC}"
  echo ""
  info "Output directory: $chart_dir"
  echo ""
  echo -e "  ${CYAN}Artifacts:${NC}"
  echo -e "    📦 Chart:            ${GREEN}${chart_tgz_file}${NC}"
  echo -e "    📄 Backend values:   ${GREEN}${backend_values_file}${NC}"
  echo -e "    📄 Override values:  ${GREEN}${cortex_override_values_file}${NC}"
  echo ""
  echo -e "  ${CYAN}Next step — install from the local chart:${NC}"
  echo ""
  echo -e "    helm upgrade --install konnector ${chart_tgz_file} \\"
  echo -e "      --wait-for-jobs \\"
  echo -e "      --create-namespace \\"
  echo -e "      --namespace ${namespace} \\"
  echo -e "      --set deployedByLauncher=false \\"
  echo -e "      --values ${cortex_override_values_file}"
  echo ""
  echo "╚══════════════════════════════════════════════════════════════════════════════════╝"

  log "Mirror complete. Pushed=$push_ok Failed=$push_fail Skipped=$push_skip"

  if [[ $push_fail -gt 0 ]]; then
    exit 1
  fi
}

# ═════════════════════════════════════════════════════════════════════════════
# Get-chart command implementation
# ═════════════════════════════════════════════════════════════════════════════
cmd_get_chart() {
  local values_file_arg=""
  local output_dir="./cortex-mirror-output"

  # ─── Parse arguments ─────────────────────────────────────────────────────
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --values)
        if [[ -z "${2:-}" ]]; then
          error "--values requires a file path argument."
          exit 1
        fi
        values_file_arg="$2"
        shift 2
        ;;
      --output-dir)
        if [[ -z "${2:-}" ]]; then
          error "--output-dir requires a directory path argument."
          exit 1
        fi
        output_dir="$2"
        shift 2
        ;;
      -h|--help)
        get_chart_usage
        ;;
      *)
        error "Unknown argument for 'get-chart': $1"
        echo ""
        get_chart_usage
        ;;
    esac
  done

  # ─── Validate required arguments ─────────────────────────────────────────
  if [[ -z "$values_file_arg" ]]; then
    error "Missing required flag: --values <values-file>"
    echo ""
    get_chart_usage
  fi

  if [[ ! -f "$values_file_arg" ]]; then
    error "Values file not found: $values_file_arg"
    exit 1
  fi

  # ─── Check prerequisites ────────────────────────────────────────────────
  check_prerequisites helm base64 yq jq tar curl
  check_helm_version

  # ─── Init logging ───────────────────────────────────────────────────────
  init_log_file
  log "Command: get-chart"
  log "Values file: $values_file_arg"
  log "Output dir: $output_dir"

  # ─── Extract distribution.id and distribution.url from values file ──────
  extract_distribution_id "$values_file_arg"

  # ─── Prepare output directory ────────────────────────────────────────────
  mkdir -p "$output_dir"
  output_dir="$(cd "$output_dir" && pwd)"

  # ─── Banner ──────────────────────────────────────────────────────────────
  echo ""
  echo -e "${BOLD}╔══════════════════════════════════════════════════════════════════════════════════╗${NC}"
  echo -e "${BOLD}║                     ${PROGRAM_NAME} get-chart                            ║${NC}"
  echo -e "${BOLD}╠══════════════════════════════════════════════════════════════════════════════════╣${NC}"
  echo ""
  info "Chart source:     Backend API"
  info "Values file:      $values_file_arg"
  info "Distribution ID:  $DIST_ID"
  info "Distribution URL: $DIST_URL"
  info "Output directory: $output_dir"
  echo ""

  # ─── Step 1: Authenticate to backend API ─────────────────────────────────
  info "Step 1/3: Authenticating to backend API..."
  ensure_backend_auth

  # ─── Step 2: Pull the Helm chart from backend ────────────────────────────
  info "Step 2/3: Fetching Helm chart from backend API..."
  chart_tgz=""
  chart_values=""
  work_dir=""
  pull_chart_from_backend

  # ─── Step 3: Copy chart to output directory ──────────────────────────────
  info "Step 3/3: Copying chart and values to output directory..."
  log "Copying chart to $output_dir"

  # Determine a meaningful filename from the chart archive
  local output_chart_name="${CHART}.tgz"

  # Try to extract chart name/version from Chart.yaml inside the archive
  local extract_dir="$work_dir/extracted"
  mkdir -p "$extract_dir"
  tar -xzf "$chart_tgz" -C "$extract_dir" 2>/dev/null || true
  local chart_yaml
  chart_yaml=$(find "$extract_dir" -name 'Chart.yaml' -print 2>/dev/null | head -1)
  if [[ -n "$chart_yaml" ]]; then
    local chart_name_from_yaml chart_version_from_yaml
    chart_name_from_yaml=$(yq '.name' "$chart_yaml" 2>/dev/null || true)
    [[ "$chart_name_from_yaml" == "null" ]] && chart_name_from_yaml=""
    chart_version_from_yaml=$(yq '.version' "$chart_yaml" 2>/dev/null || true)
    [[ "$chart_version_from_yaml" == "null" ]] && chart_version_from_yaml=""
    if [[ -n "$chart_name_from_yaml" && -n "$chart_version_from_yaml" ]]; then
      output_chart_name="${chart_name_from_yaml}-${chart_version_from_yaml}.tgz"
      chart_version_label="$chart_version_from_yaml"
    elif [[ -n "$chart_name_from_yaml" ]]; then
      output_chart_name="${chart_name_from_yaml}.tgz"
    fi
  fi
  local chart_version_label="${chart_version_label:-unknown}"

  cp "$chart_tgz" "$output_dir/$output_chart_name"
  ok "Chart copied to: $output_dir/$output_chart_name"
  log "Chart copied: $output_dir/$output_chart_name"

  # Extract namespace and image.repository for the header comment
  local namespace
  namespace=$(jq -r '.namespace.name // "panw"' "$chart_values" 2>/dev/null || echo "panw")

  local image_repo_from_backend
  image_repo_from_backend=$(jq -r '.image.repository // "N/A"' "$chart_values" 2>/dev/null || echo "N/A")

  # Convert backend-provided values from JSON to YAML with descriptive header
  local backend_values_yaml="$output_dir/backend-values.yaml"

  cat > "$backend_values_yaml" <<BVEOF
# ============================================================================
# backend-values.yaml
# Generated by: ${PROGRAM_NAME} get-chart
# Source: Backend API
# Registry:       ${image_repo_from_backend}
# Chart version:  ${chart_version_label}
#
# Merged values: backend API values + user input values (input takes priority).
# Use this file directly for installation, or run '${PROGRAM_NAME} mirror'
# to generate cortex-override-values.yaml with a private registry.
#
# Usage (install from local chart):
#   helm upgrade --install konnector ./${output_chart_name} \\
#     --wait-for-jobs \\
#     --create-namespace \\
#     --namespace ${namespace} \\
#     --set deployedByLauncher=false \\
#     --values backend-values.yaml
# ============================================================================

BVEOF
  # Merge backend values with user input values (input takes priority via deep merge)
  # Backend values = base, user input values = override
  info "Merging backend values with user input values (input values take priority)..."
  local input_values_json
  input_values_json=$(yq -o=json '.' "$values_file_arg" 2>/dev/null)

  jq -s '
    def deepmerge:
      reduce .[] as $item ({}; . as $base |
        $item | to_entries | reduce .[] as $e ($base;
          if ($e.value | type) == "object" and (.[$e.key] | type) == "object"
          then .[$e.key] = ([ .[$e.key], $e.value ] | deepmerge)
          else .[$e.key] = $e.value
          end
        )
      );
    deepmerge | del(.otelValues.agentId) | del(.metadata.agentID) | del(.image)
  ' "$chart_values" <(echo "$input_values_json") | yq -P >> "$backend_values_yaml"

  ok "Merged values saved to: $backend_values_yaml (input values override backend values)"
  log "Merged values saved: $backend_values_yaml"

  # ─── Final output summary ───────────────────────────────────────────────
  echo ""
  echo -e "${BOLD}╔══════════════════════════════════════════════════════════════════════════════════╗${NC}"
  echo -e "${BOLD}║                        GET-CHART COMPLETE                                      ║${NC}"
  echo -e "${BOLD}╠══════════════════════════════════════════════════════════════════════════════════╣${NC}"
  echo ""
  info "Output directory: $output_dir"
  echo ""
  echo -e "  ${CYAN}Artifacts:${NC}"
  echo -e "    📦 Chart:            ${GREEN}$output_dir/$output_chart_name${NC}"
  echo -e "    📄 Backend values:   ${GREEN}$output_dir/backend-values.yaml${NC}"
  echo ""
  echo -e "  ${CYAN}Next steps:${NC}"
  echo ""
  echo -e "    ${YELLOW}Install directly:${NC}"
  echo -e "       helm upgrade --install konnector ${output_dir}/${output_chart_name} \\"
  echo -e "         --wait-for-jobs \\"
  echo -e "         --create-namespace \\"
  echo -e "         --namespace ${namespace} \\"
  echo -e "         --set deployedByLauncher=false \\"
  echo -e "         --values ${output_dir}/backend-values.yaml"
  echo ""
  echo -e "    ${YELLOW}Use a private registry?${NC} Mirror images first:"
  echo -e "       ${PROGRAM_NAME} mirror \\"
  echo -e "         --chart-dir ${output_dir} \\"
  echo -e "         --values ${values_file_arg} \\"
  echo -e "         --private-registry <your-registry> \\"
  echo -e "         --docker-pull-secret-file <path-to-docker-config.json>"
  echo ""
  echo -e "    ${RED}⚠️  Important:${NC} When using a private registry, you ${BOLD}must${NC} provide a dockerPullSecret"
  echo -e "       so the Kubernetes cluster can pull images. Use one of:"
  echo -e "         --docker-pull-secret <base64-encoded-secret>"
  echo -e "         --docker-pull-secret-file <path-to-docker-config.json>"
  echo -e "       Skip with --no-pull-secret only if your cluster has pre-configured access."
  echo ""
  echo "╚══════════════════════════════════════════════════════════════════════════════════╝"

  log "get-chart complete"
}

# ═════════════════════════════════════════════════════════════════════════════
# Main entry point — route to subcommands
# ═════════════════════════════════════════════════════════════════════════════
main() {
  if [[ $# -eq 0 ]]; then
    usage
  fi

  local command="$1"
  shift

  case "$command" in
    mirror)
      cmd_mirror "$@"
      ;;
    get-chart)
      cmd_get_chart "$@"
      ;;
    -h|--help)
      usage
      ;;
    -v|--version)
      echo "${PROGRAM_NAME} v${VERSION}"
      exit 0
      ;;
    *)
      error "Unknown command: $command"
      echo ""
      usage
      ;;
  esac
}

main "$@"
