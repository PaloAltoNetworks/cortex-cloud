#!/usr/bin/env bash
#
# cortex-installer
#
# A CLI tool for managing Cortex Kubernetes agent deployments.
# This variant pulls the Helm chart and values from the backend API
# instead of from an OCI registry.
#
# Commands:
#   mirror      Pull container images from source registry and push to a target registry
#   get-chart   Download the Helm chart locally and generate a cortex-override-values.yaml
#
# Prerequisites:
#   - helm (v3.8+)
#   - docker (with buildx for multi-arch support)
#   - base64, yq (v4, mikefarah), jq, tar, curl
#
# Usage:
#   cortex-installer <command> [options]
#
# Examples:
#   # Step 1: Get the chart and values from the backend API
#   cortex-installer get-chart --values <values-file>
#
#   # Step 2 (optional): Mirror images to a private registry
#   cortex-installer mirror --chart-dir ./cortex-mirror-output --values my-values.yaml --private-registry myregistry.azurecr.io/project/repo
#

set -euo pipefail

# ═════════════════════════════════════════════════════════════════════════════
# Constants & Color helpers
# ═════════════════════════════════════════════════════════════════════════════
readonly VERSION="1.0.0"
readonly PROGRAM_NAME="cortex-installer"
readonly MIN_HELM_MAJOR=3
readonly MIN_HELM_MINOR=8

# ── Backend config (from env or defaults) ──────────────────────────────────
DIST_URL="${DISTRIBUTION_URL:-https://distributions-dev.traps.paloaltonetworks.com}"
CH_API="${CH_API:-}"
[[ "$CH_API" == "--set-by-"* ]] && CH_API=""
CHART="${HELM_CHART_NAME:-konnector-bundle}"

# ── TTY-aware color output ─────────────────────────────────────────────────
# Only emit ANSI color codes when stdout is connected to a terminal.
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  NC='\033[0m'
else
  RED=''
  GREEN=''
  YELLOW=''
  CYAN=''
  BOLD=''
  NC=''
fi

info()  { echo -e "${CYAN}[INFO]${NC}  $*"; }
ok()    { echo -e "${GREEN}[OK]${NC}    $*"; }
warn()  { echo -e "${YELLOW}[WARN]${NC}  $*"; }
error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

# ═════════════════════════════════════════════════════════════════════════════
# Logging to file (audit trail)
# ═════════════════════════════════════════════════════════════════════════════
LOG_FILE=""

init_log_file() {
  LOG_FILE=$(mktemp /tmp/cortex-installer-log-XXXXXX.log)
  _TEMP_FILES+=("$LOG_FILE")
  info "Log file: $LOG_FILE"
}

log() {
  local timestamp
  timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  if [[ -n "$LOG_FILE" && -w "$LOG_FILE" ]]; then
    echo "[$timestamp] $*" >> "$LOG_FILE"
  fi
}

# ═════════════════════════════════════════════════════════════════════════════
# Temp file tracking & trap-based cleanup
# ═════════════════════════════════════════════════════════════════════════════
# All temp files/dirs are registered here and cleaned up on EXIT.
declare -a _TEMP_FILES=()
declare -a _TEMP_DIRS=()

register_temp_file() { _TEMP_FILES+=("$1"); }
register_temp_dir()  { _TEMP_DIRS+=("$1"); }

cleanup() {
  local exit_code=$?
  for f in "${_TEMP_FILES[@]:-}"; do
    [[ -n "$f" && -f "$f" ]] && rm -f "$f"
  done
  for d in "${_TEMP_DIRS[@]:-}"; do
    [[ -n "$d" && -d "$d" ]] && rm -rf "$d"
  done
  if [[ $exit_code -ne 0 && -n "$LOG_FILE" && -f "$LOG_FILE" ]]; then
    warn "Non-zero exit ($exit_code). Log preserved at: $LOG_FILE"
  fi
  exit "$exit_code"
}

trap cleanup EXIT

# Handle SIGINT/SIGTERM for graceful shutdown
on_signal() {
  echo ""
  warn "Caught signal — shutting down gracefully..."
  log "Caught signal — shutting down"
  exit 130
}

trap on_signal INT TERM

# ═════════════════════════════════════════════════════════════════════════════
# Portable base64 decode
# ═════════════════════════════════════════════════════════════════════════════
# macOS uses `base64 -D`, GNU/Linux uses `base64 -d`.
base64_decode() {
  if base64 --help 2>&1 | grep -q '\-D'; then
    base64 -D
  else
    base64 -d
  fi
}

# ═════════════════════════════════════════════════════════════════════════════
# Top-level usage
# ═════════════════════════════════════════════════════════════════════════════
usage() {
  echo -e "${BOLD}${PROGRAM_NAME}${NC} v${VERSION}"
  echo ""
  echo "Usage:"
  echo "  ${PROGRAM_NAME} <command> [options]"
  echo ""
  echo "Commands:"
  echo "  get-chart   Download the Helm chart and values from the backend API (run this first)"
  echo "  mirror      Mirror container images to a private registry (requires get-chart output)"
  echo ""
  echo "Global Options:"
  echo "  -h, --help      Show this help message"
  echo "  -v, --version   Show version"
  echo ""
  echo "Environment Variables:"
  echo "  DISTRIBUTION_URL       Distribution service URL (default: https://distributions-dev.traps.paloaltonetworks.com)"
  echo "  CH_API                 Backend API URL (resolved from distribution service if not set)"
  echo "  HELM_CHART_NAME        Chart name to fetch from backend (default: konnector-bundle)"
  echo ""
  echo "Run '${PROGRAM_NAME} <command> --help' for command-specific help."
  exit 0
}

